scythed = rpois(15, 20)
grazed = rpois(15, 25)
shapiro.test(scythed)
shapiro.test(grazed)
wilcox.test(scythed, grazed)
set.seed(42)
male = rnorm(30, 393, 20.3)
female = rnorm(30, 380, 40.2)
shapiro.test(male)
shapiro.test(female)
var.test(male, female)
t.test(male, female, var.equal = FALSE)

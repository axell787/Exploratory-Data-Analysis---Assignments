fear = sample(1:10, 50, replace = TRUE)
distance = rnorm(50, 100, 30)
#test normality
shapiro.test(fear)
shapiro.test(distance)
cor.test(fear, distance, method = "spearman")
plot(x = distance, y = fear, type = scatter)
plot(x = distance, y = fear, type = "scatter")
plot(x = distance, y = fear)
lines(~distance+fear)
lines(lm(~distance+fear))
plot(x = distance, y = fear)
lines(lm(~distance+fear))
plot(x = distance, y = fear)
abline(lm(~distance+fear))
plot(x = distance, y = fear)
abline(lm(~fear+distance))
plot(x = distance, y = fear)
abline(lm(~fear+distance))
plot(x = distance, y = fear) +
abline(lm(~fear+distance))
plot(x = distance, y = fear) +
abline(lm(~fear+distance))
plot(x = distance, y = fear)
abline(lm(fear ~ distance))
xtabs = (~forest_type+color_morph)
tab = xtabs(~forest_type+color)

# Assuming your dataset is named 'runoff_monthly'
# 1. We convert 'month' to a factor so it appears as discrete categories on the x-axis.
# 2. We map 'fill' to 'runoff_class' to get different colors.
ggplot(runoff_monthly, aes(x = factor(month), y = runoff, fill = runoff_class)) +
geom_boxplot() +
# Create a separate plot for each station
facet_wrap(~sname) +
theme_bw() +
labs(
title = "Monthly Runoff Distribution by Station",
x = "Month",
y = "Runoff",
fill = "Runoff Class"
) +

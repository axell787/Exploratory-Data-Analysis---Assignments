color_morph <- sample(c("Red", "Black"), 100, replace = TRUE)
tab = xtabs(~forest_type+color)
set.seed(123)
forest_type <- sample(c("Deciduous", "Coniferous"), 100, replace = TRUE)
color_morph <- sample(c("Red", "Black"), 100, replace = TRUE)
tab = xtabs(~forest_type+color_morph)
tab
#H0: forest type is not dependent on color morph
#H1: forest type is dependent on color morph
chisq.test(tab)
#H0: forest type is not dependent on color morph
#H1: forest type is dependent on color morph
result = chisq.test(tab)
result$expected

set.seed(24)
rabbits  = rnorm(35, 2.5, 0.6)
set.seed(24)
rabbits  = rnorm(35, 2.5, 0.6)
rabbits  = rnorm(35, 2.5, 0.6)
rabbits  = abs(rnorm(35, 2.5, 0.6))
#test the assumption
#the distribution of the rabbit weight is normal
#shapiro-wilk's test of normality
#H0: the shape of the distribution does not differ from normal distribution
shapiro.test(rabbits)
set.seed(24)
rabbits = abs(rnorm(35, 2.5, 0.6))
#is the mean weight of the rabbits equal to 3kg?
#H0: the mean rabbit weight is equal to 3kg
#H1: the mean rabbit weight is not equal to 3 kg
#test the assumption
#the distribution of the rabbit weight is normal
#shapiro-wilk's test of normality
#H0: the shape of the distribution does not differ from normal distribution
shapiro.test(rabbits)
# p = 0.29 > 0.05 => we do not reject H0 => distribution is normal
set.seed(24)
rabbits = abs(rnorm(35, 2.5, 0.6))
#is the mean weight of the rabbits equal to 3kg?
#H0: the mean rabbit weight is equal to 3kg
#H1: the mean rabbit weight is not equal to 3 kg
#test the assumption
#the distribution of the rabbit weight is normal
#shapiro-wilk's test of normality
#H0: the shape of the distribution does not differ from normal distribution
shapiro.test(rabbits)
# p = 0.29 > 0.05 => we do not reject H0 => distribution is normal
shapiro.test(c(0:300))
#can we use the one-sample t-test and interval estimate
t.test(x = rabbits, mu = 3)
#H0 is rejected (p = 2e-8 < 0.05), the weight is different form 3 kg
boxplot(rabbits)
#H0 is rejected (p = 2e-8 < 0.05), the weight is different form 3 kg
boxplot(rabbits, notch = T)
wilcox.test(x = rabbits, mu = 3, alternative = "less")
wilcox.test(x = rabbits, mu = 3, alternative = "less", int = T)
wilcox.test(x = rabbits, mu = 3, alternative = "less", int = T)
wilcox.test(x = rabbits, mu = 3, alternative = "less", conf.int = T)
set.seed(7)
rabbits=rnorm(n = 30,mean = 8,sd = 1)
# Point estimate of the mean is 8.396
m=mean(rabbits)
set.seed(7)
rabbits=rnorm(n = 30,mean = 8,sd = 1)
# Point estimate of the mean is 8.396
m=mean(rabbits)
m-t*s/sqrt(30)
# Point estimate of sd is 1.126
s=sd(rabbits)
# We will use a 97.5 % quantile of t distribution
t=qt(p = 0.975, df = 29)
# Left side of the interval
m-t*s/sqrt(30)
# Right side of the interval
m+t*s/sqrt(30)
# Two sided 95% interval estimate is (7.975;8.816)
t.test(x = rabbits) # just to check the interval
# H0: The shape of our distribution does not differ
# from the shape of normal distribution
# H1: The shape of our distribution does differ
# from the shape of normal distribution
shapiro.test(x = rabbits)
# Graphical representation of rabbit weights with a asymptotic 95% confidence interval of the median (notch)
boxplot(rabbits,notch = T)
t.test(rabbits,mu = 7)
# We will use a 95 % quantile of t distribution
t=qt(p = 0.95, df = 29)
# Left side of the interval
m-t*s/sqrt(30)
# Left sided 95% interval estimate is (8.046;Inf)
t.test(x = rabbits, alternative = "greater") # just to check the interval
